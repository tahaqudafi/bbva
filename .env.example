# ── Deepgram ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Deepgram STT model  (e.g. nova-2, nova-2-phonecall, enhanced)
DEEPGRAM_STT_MODEL=nova-2

# Deepgram TTS voice  (e.g. aura-asteria-en, aura-luna-en, aura-zeus-en)
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model  (e.g. google/gemini-flash-1.5, openai/gpt-4o-mini)
OPENROUTER_MODEL=google/gemini-flash-1.5

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=primary
GOOGLE_TIMEZONE=Europe/Madrid

# ── Business hours ────────────────────────────────────────────────────────────
BUSINESS_START_HOUR=09:00
BUSINESS_END_HOUR=17:00
APPOINTMENT_DURATION_MINUTES=30

# ── Audio (advanced — defaults work for most Windows setups) ──────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
# Barge-in sensitivity: raise if background noise triggers false interruptions
VAD_ENERGY_THRESHOLD=0.005

# ── File paths (defaults match project layout) ────────────────────────────────
KNOWLEDGE_DIR=knowledge
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json